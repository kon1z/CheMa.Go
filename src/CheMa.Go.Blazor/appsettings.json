{
  "App": {
    "SelfUrl": "https://localhost:44338",
    "RedirectAllowedUrls": "https://localhost:44338",
    "DisablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=CheMaGo;User ID=postgres;Password=myPassword;"
  },
  "AuthServer": {
    "Authority": "https://localhost:44338",
    "RequireHttpsMetadata": true,
    "CertificatePassPhrase": "78c65fcd-e29a-4159-8886-62dd6bacbcfb"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "loNLlTtNYI0OCnaf"
  }
}
