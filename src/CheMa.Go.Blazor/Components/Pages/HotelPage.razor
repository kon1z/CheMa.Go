@page "/hotels"
@inherits AbpCrudPageBase<IHotelAppService, HotelDto, long, GetListHotelInput, CreateHotelInput, UpdateHotelInput>
@using CheMa.Go.Localization
@using CheMa.Go.Applications.AppServices
@using CheMa.Go.Applications.Dtos
@using Volo.Abp.AspNetCore.Components.Web
@using Volo.Abp.AspNetCore.Components.Web.Theming.Layout
@using Volo.Abp.Identity
@inject PageLayout PageLayout
@inject AbpBlazorMessageLocalizerHelper<GoResource> LH
@{
    PageLayout.Title = L["Menu:Home"];
    PageLayout.ShowToolbar = false;
}

<Card>
    <CardHeader>
        <Row Class="justify-content-between">
            <Column ColumnSize="ColumnSize.IsAuto">
                <h2>@L["Menu:HotelManagement"]</h2>
            </Column>
            <Column ColumnSize="ColumnSize.IsAuto">
                <Button Color="Color.Primary"
                        Clicked="OpenCreateModalAsync">
                    @L["New"]
                </Button>
            </Column>
        </Row>
    </CardHeader>
    <CardBody>
        <DataGrid TItem="HotelDto"
                  Data="Entities"
                  ReadData="OnDataGridReadAsync"
                  TotalItems="TotalCount"
                  ShowPager="true"
                  PageSize="PageSize"
                  DetailRowTrigger="@(e => DisplayDetailRow(e.Item))"
                  DetailRowStartsVisible="false"
                  Responsive>
            <DataGridColumns>
                <DataGridEntityActionsColumn TItem="HotelDto" @ref="@EntityActionsColumn">
                    <DisplayTemplate>
                        <EntityActions TItem="HotelDto" EntityActionsColumn="@EntityActionsColumn">
                            <EntityAction TItem="HotelDto"
                                          Text="@L["Edit"]"
                                          Clicked="() => OpenEditModalAsync(context)" />
                            <EntityAction TItem="HotelDto"
                                          Text="@L["LinkUser"]"
                                          Clicked="() => OpenLinkUserModalAsync(context)" />
                            <EntityAction TItem="HotelDto"
                                          Text="@L["Delete"]"
                                          Clicked="() => DeleteEntityAsync(context)"
                                          ConfirmationMessage="() => GetDeleteConfirmationMessage(context)" />
                        </EntityActions>
                    </DisplayTemplate>
                </DataGridEntityActionsColumn>
                <DataGridColumn TItem="HotelDto"
                                Field="@nameof(HotelDto.Name)"
                                Caption="@L["HotelDto:Name"]">
                </DataGridColumn>
            </DataGridColumns>
            <DetailRowTemplate>
                <DataGrid TItem="IdentityUserDto"
                          Data="context.HotelUsers"
                          Sortable="false"
                          ShowCaptions="true"
                          Responsive>
                    <DataGridColumn TItem="IdentityUserDto" Field="@nameof(IdentityUserDto.Id)" Caption="@L["Actions"]">
                        <DisplayTemplate Context="user">
                            <Button Color="Color.Danger" Size="Size.Small" Clicked="() => RemoveUserFromHotelAsync(user, context)">@L["Delete"]</Button>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(IdentityUserDto.Id)" Caption="@L["IdentityUserDto:Id"]"/>
                    <DataGridColumn Field="@nameof(IdentityUserDto.UserName)" Caption="@L["IdentityUserDto:UserName"]"/>
                    <DataGridColumn Field="@nameof(IdentityUserDto.PhoneNumber)" Caption="@L["IdentityUserDto:PhoneNumber"]"/>
                </DataGrid>
            </DetailRowTemplate>
        </DataGrid>
    </CardBody>
</Card>


<Modal @ref="@CreateModal">
    <ModalContent IsCentered="true">
        <Form>
            <ModalHeader>
                <ModalTitle>@L["New"]</ModalTitle>
                <CloseButton Clicked="CloseCreateModalAsync" />
            </ModalHeader>
            <ModalBody>
                <Validations @ref="@CreateValidationsRef" Model="@NewEntity" ValidateOnLoad="false">
                    <Field>
                        <FieldLabel>@L["HotelDto:Name"]</FieldLabel>
                        <TextEdit @bind-Text="@NewEntity.Name">
                            <Feedback>
                                <ValidationError />
                            </Feedback>
                        </TextEdit>
                    </Field>
                </Validations>
            </ModalBody>
            <ModalFooter>
                <Button Color="Color.Secondary"
                        Clicked="CloseCreateModalAsync">
                    @L["Cancel"]
                </Button>
                <Button Color="Color.Primary"
                        Type="@ButtonType.Submit"
                        PreventDefaultOnSubmit="true"
                        Clicked="CreateEntityAsync">
                    @L["Save"]
                </Button>
            </ModalFooter>
        </Form>
    </ModalContent>
</Modal>


<Modal @ref="@EditModal">
    <ModalContent IsCentered="true">
        <Form>
            <ModalHeader>
                <ModalTitle>@EditingEntity.Name</ModalTitle>
                <CloseButton Clicked="CloseEditModalAsync" />
            </ModalHeader>
            <ModalBody>
                <Validations @ref="@EditValidationsRef" Model="@EditingEntity" ValidateOnLoad="false">
                    <Validation MessageLocalizer="@LH.Localize">
                        <Field>
                            <FieldLabel>@L["HotelDto:Name"]</FieldLabel>
                            <TextEdit @bind-Text="@EditingEntity.Name">
                                <Feedback>
                                    <ValidationError />
                                </Feedback>
                            </TextEdit>
                        </Field>
                    </Validation>
                </Validations>
            </ModalBody>
            <ModalFooter>
                <Button Color="Color.Secondary"
                        Clicked="CloseEditModalAsync">
                    @L["Cancel"]
                </Button>
                <Button Color="Color.Primary"
                        Type="@ButtonType.Submit"
                        PreventDefaultOnSubmit="true"
                        Clicked="UpdateEntityAsync">
                    @L["Save"]
                </Button>
            </ModalFooter>
        </Form>
    </ModalContent>
</Modal>

<Modal @ref="@LinkUserModal">
    <ModalContent Centered="true">
        <ModalHeader>
            <ModalTitle>@LinkedHotelName</ModalTitle>
            <CloseButton Clicked="CloseLinkUserModalAsync" />
        </ModalHeader>
        <ModalBody>
            <Field>
                <FieldLabel>@L["HotelDto:Name"]</FieldLabel>
                <TextEdit ReadOnly="true" @bind-Text="LinkedHotelName"></TextEdit>
            </Field>
            <Field>
                <FieldLabel>@L["LinkUsersToHotelInput:UserIds"]</FieldLabel>
                <Autocomplete TItem="IdentityUserDto"
                              TValue="Guid"
                              Data="@FilteredUsers"
                              TotalItems="TotalUsersCount"
                              TextField="@(user => user.UserName)"
                              ValueField="@(user => user.Id)"
                              @bind-SelectedValues="@LinkUsersToHotelInput.UserIds"
                              SelectionMode="AutocompleteSelectionMode.Multiple"
                              Virtualize
                              ReadData="@OnUsersReadData"
                              SearchBackground="Background.White"
                              MultipleDisabledBadgeColor="Color.Light"
                              MultipleBadgeColor="Color.Light">
                    <NotFoundContent>
                        @string.Format(L["InputNotFound"], context)
                    </NotFoundContent>
                </Autocomplete>
            </Field>
        </ModalBody>
        <ModalFooter>
            <Button Color="Color.Secondary" Clicked="@CloseLinkUserModalAsync">
                @L["Cancel"]
            </Button>
            <Button Color="Color.Primary"
                    Type="@ButtonType.Submit"
                    PreventDefaultOnSubmit="true"
                    Clicked="LinkUsersToHotelAsync">
                @L["Save"]
            </Button>
        </ModalFooter>
    </ModalContent>
</Modal>
